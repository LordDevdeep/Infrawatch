# ─── INFRAWATCH BACKEND CONFIG ──────────────────────────────────────────────
PORT=3002
JWT_SECRET=replace_with_a_long_random_string_in_production

# ─── AI PROVIDER ────────────────────────────────────────────────────────────
# Primary provider (recommended: gemini — free API key from aistudio.google.com)
AI_PROVIDER=gemini

# Google Gemini via AI Studio (FREE, no credit card required)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Groq (optional, used as fallback if Gemini rate-limits)
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
